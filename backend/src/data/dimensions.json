  "definitions": {
    "N1": {
      "name": "N1 路感自信",
      "model": "导航心理",
      "shortName": "路感",
      "levels": {
        "L": "断网就慌，全靠导航续命，路感为零。",
        "M": "熟路还行，陌生地区还是得看手机。",
        "H": "去过一次基本都记得，路感不错。"
      }
    },
    "N2": {
      "name": "N2 目标清晰度",
      "model": "导航心理",
      "shortName": "目标",
      "levels": {
        "L": "去哪都随缘，走到哪算哪。",
        "M": "大方向有，细节随机。",
        "H": "每次出行目的明确，不随便。"
      }
    },
    "N3": {
      "name": "N3 出行驱动力",
      "model": "导航心理",
      "shortName": "驱动",
      "levels": {
        "L": "重过程，不在意快不快。",
        "M": "到达和过程都有点在乎。",
        "H": "效率优先，到达才是正义。"
      }
    },
    "C1": {
      "name": "C1 路途焦虑感",
      "model": "车内情感",
      "shortName": "焦虑",
      "levels": {
        "L": "导航出问题就开始脑补大结局。",
        "M": "一半信任，一半拉锯。",
        "H": "走错了再调整，不太会乱。"
      }
    },
    "C2": {
      "name": "C2 出行投入度",
      "model": "车内情感",
      "shortName": "投入",
      "levels": {
        "L": "凑合就行，差不多得了。",
        "M": "会投入，但不至于全力以赴。",
        "H": "每次出行都认真对待，不含糊。"
      }
    },
    "C3": {
      "name": "C3 独行边界感",
      "model": "车内情感",
      "shortName": "独行",
      "levels": {
        "L": "喜欢有人陪，副驾最好别空着。",
        "M": "有没有人都行，弹性大。",
        "H": "开车是我的独处时间，别来。"
      }
    },
    "R1": {
      "name": "R1 司机世界观",
      "model": "路途态度",
      "shortName": "世界观",
      "levels": {
        "L": "路上全是烂司机，我先假设坏意图。",
        "M": "观望，不天真也不偏执。",
        "H": "大部分人还是守规矩的。"
      }
    },
    "R2": {
      "name": "R2 规则灵活度",
      "model": "路途态度",
      "shortName": "规则",
      "levels": {
        "L": "规则能绕就绕，舒服第一。",
        "M": "该守的守，该变通的变通。",
        "H": "规则就是规则，不打折扣。"
      }
    },
    "R3": {
      "name": "R3 出行意义感",
      "model": "路途态度",
      "shortName": "意义",
      "levels": {
        "L": "出行就是位移，没什么特别意义。",
        "M": "偶尔觉得有意思，偶尔没感觉。",
        "H": "每段路都有意义，不只是A到B。"
      }
    },
    "A1": {
      "name": "A1 冒险导向",
      "model": "行动模式",
      "shortName": "冒险",
      "levels": {
        "L": "安全第一，宁可慢也不翻车。",
        "M": "兼顾速度和安全，看情况。",
        "H": "效率优先，快才是硬道理。"
      }
    },
    "A2": {
      "name": "A2 路线决策力",
      "model": "行动模式",
      "shortName": "决策",
      "levels": {
        "L": "导航三条路反复比，脑内会议超时。",
        "M": "会想，但不至于卡死机。",
        "H": "第一条，发车，不磨叽。"
      }
    },
    "A3": {
      "name": "A3 行程执行力",
      "model": "行动模式",
      "shortName": "执行",
      "levels": {
        "L": "执行力和死线深厚感情，越晚越觉醒。",
        "M": "能做，但状态看时机。",
        "H": "不充电不出发，出发了就不乱。"
      }
    },
    "S1": {
      "name": "S1 拼车主动性",
      "model": "社交出行",
      "shortName": "拼车",
      "levels": {
        "L": "社交启动慢，主动拼车得攒很久气。",
        "M": "有人来就接，没人来也不硬凑。",
        "H": "喜欢有人同行，主动召集。"
      }
    },
    "S2": {
      "name": "S2 车内边界感",
      "model": "社交出行",
      "shortName": "边界",
      "levels": {
        "L": "熟了就随便，想改啥改啥。",
        "M": "看对象调节，弹性大。",
        "H": "坐人车要守规矩，有边界感。"
      }
    },
    "S3": {
      "name": "S3 路况分享度",
      "model": "社交出行",
      "shortName": "分享",
      "levels": {
        "L": "遇到好事烂事都喜欢说出来。",
        "M": "偶尔分享，不强迫。",
        "H": "不爱在外表达，保持低调。"
      }
    }
  }
}
