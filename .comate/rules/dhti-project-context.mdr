│       └── data/               # 数据源：questions/dimensions/types/config.json
├── frontend/
│   ├── vite.config.js          # 已配置 @ 别名指向 src/
│   └── src/
│       ├── views/              # HomeView / QuizView / ResultView（三个均已存在）
│       ├── components/         # DimDetail / ProgressBar / QuizQuestion / RadarChart / Top5List
│       ├── stores/quiz.js      # Pinia store id='quiz'
│       ├── router/index.js     # Vue Router 路由配置
│       ├── api/quiz.js         # 前端 HTTP 调用封装（含离线降级逻辑）
│       ├── engine/scoring.js   # 与后端同步的评分引擎副本
│       ├── assets/types/       # 【待添加】每种人格的角色配图 {code}.png
│       └── data/               # 与后端同步的数据副本（修改需两处同步）
└── docs/
    ├── algorithm.md            # 算法文档（SBTI原理/MBTI-SBTI-DHTI三层体系/评分算法/类型全表）
    ├── character-prompts.md    # 27种人格 AI 生图提示词（含每种类型的MBTI/SBTI对应注释）
